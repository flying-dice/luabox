<idea-plugin>
    <!-- id / name / version / vendor / idea-version are injected at build time
         from the `intellijPlatform { pluginConfiguration { ... } }` block in
         build.gradle.kts — do not duplicate them here. -->

    <!-- Base platform. -->
    <depends>com.intellij.modules.platform</depends>
    <!-- Native LSP client API (com.intellij.platform.lsp). The dedicated
         `com.intellij.modules.lsp` module exists from 2025.2 (matching our
         sinceBuild=252) and gates the plugin to IDEs that ship the API. -->
    <depends>com.intellij.modules.lsp</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- `.lua` sources, backed by the namespaced luabox.Lua language:
             first-class file type instead of plain text + marketplace
             plugin suggestions. -->
        <fileType
                name="Lua (luabox)"
                implementationClass="com.luabox.LuaFileType"
                fieldName="INSTANCE"
                language="luabox.Lua"
                extensions="lua"/>

        <!-- Base lexical highlighting for .lua (keywords/strings/numbers/
             comments); LSP semantic tokens overlay semantic colour on top. -->
        <lang.syntaxHighlighterFactory
                language="luabox.Lua"
                implementationClass="com.luabox.LuaSyntaxHighlighterFactory"/>

        <!-- Start `luabox lsp` for .lua files. -->
        <platform.lsp.serverSupportProvider
                implementation="com.luabox.LuaboxLspServerSupportProvider"/>

        <!-- Settings ▸ Tools ▸ luabox — the executable path. -->
        <applicationConfigurable
                instance="com.luabox.LuaboxConfigurable"
                id="com.luabox.settings"
                parentId="tools"
                displayName="luabox"/>
    </extensions>
</idea-plugin>
