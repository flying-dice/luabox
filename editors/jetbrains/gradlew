# Standard Gradle wrapper launcher (Gradle 8.x). Requires
# gradle/wrapper/gradle-wrapper.jar — if it is missing, run `gradle wrapper`
# once (or let IntelliJ IDEA generate it on Gradle import). See README.md.

set -e

APP_HOME=$( cd "$( dirname "$0" )" >/dev/null && pwd )
CLASSPATH="$APP_HOME/gradle/wrapper/gradle-wrapper.jar"

if [ ! -f "$CLASSPATH" ]; then
    echo "gradle-wrapper.jar not found. Bootstrap it once with:" >&2
    echo "  gradle wrapper --gradle-version 8.10.2" >&2
    echo "or open editors/jetbrains in IntelliJ IDEA and let it import the" >&2
    echo "Gradle project (it generates the wrapper jar automatically)." >&2
    exit 1
fi

# Determine the Java command to use.
if [ -n "$JAVA_HOME" ] ; then
    JAVACMD="$JAVA_HOME/bin/java"
else
    JAVACMD="java"
fi

exec "$JAVACMD" -classpath "$CLASSPATH" org.gradle.wrapper.GradleWrapperMain "$@"
